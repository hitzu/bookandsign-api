meta {
  name: delete photo photobooth
  type: http
  seq: 8
}

delete {
  url: {{base_url}}/photos/photobooth/{{id}}
  body: none
  auth: inherit
}

headers {
  x-photobooth-key: brillipoint-photobooth-key
  ~Authorization: Bearer {{token}}
}

vars:pre-request {
  id: 1
}

settings {
  encodeUrl: true
  timeout: 0
}
