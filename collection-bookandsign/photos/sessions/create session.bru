meta {
  name: create session
  type: http
  seq: 4
}

post {
  url: {{base_url}}/sessions
  body: json
  auth: none
}

body:json {
  {
    "sessionToken": "{{session_token}}",
    "eventToken": "{{event_token}}"
  }
}

vars:pre-request {
  session_token: c1d2e3f4-0000-4000-8000-cabbccddeeff
  event_token: 4b5afc47-18a8-4df2-a9eb-4855dea500de
}

settings {
  encodeUrl: true
  timeout: 0
}
