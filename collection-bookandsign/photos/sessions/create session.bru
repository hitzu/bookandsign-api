meta {
  name: create session
  type: http
  seq: 4
}

post {
  url: {{base_url}}/sessions
  body: json
  auth: none
}

body:json {
  {
    "sessionToken": "{{session_token}}",
    "eventToken": "{{event_token}}"
  }
}

vars:pre-request {
  session_token: c1d2e3f4-0000-4000-8000-cabbccddeeff
  event_token: db69c995-b30b-40b4-85e7-c01a79eff1a1
}

settings {
  encodeUrl: true
  timeout: 0
}
