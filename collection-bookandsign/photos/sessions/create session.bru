meta {
  name: create session
  type: http
  seq: 4
}

post {
  url: {{base_url}}/sessions
  body: json
  auth: none
}

body:json {
  {
    "sessionToken": "{{session_token}}",
    "eventToken": "{{event_token}}"
  }
}

vars:pre-request {
  session_token: c1d2e3f4-0000-4000-8000-babbccddeeff
  event_token: 3e337d28-26f2-4de9-8944-5dcab0ab359b
}

settings {
  encodeUrl: true
  timeout: 0
}
