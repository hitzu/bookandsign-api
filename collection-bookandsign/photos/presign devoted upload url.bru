meta {
  name: presign devoted upload url
  type: http
  seq: 7
}

post {
  url: {{base_url}}/photos/event/{{event_token}}/devoted/upload-url
  body: json
  auth: inherit
}

headers {
  ~Authorization: Bearer {{token}}
}

body:json {
  {
    "fileName": "photo_dedicated_2026-03-28T12-30-00.jpg",
    "mime": "image/jpeg",
    "storageEnv": "{{env}}"
  }
}

vars:pre-request {
  event_token: 8891fd61-446f-4a9a-9cd8-6cf053b36010
  env: local
}

settings {
  encodeUrl: true
  timeout: 0
}
