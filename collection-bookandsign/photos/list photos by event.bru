meta {
  name: list photos by event
  type: http
  seq: 1
}

get {
  url: {{base_url}}/photos/event/{{event_token}}?limit={{limit}}&cursor={{cursor}}
  body: none
  auth: inherit
}

headers {
  ~Authorization: Bearer {{token}}
}

vars:pre-request {
  event_token: 8891fd61-446f-4a9a-9cd8-6cf053b36010
  limit: 2
  cursor: eyJjcmVhdGVkQXQiOiIyMDI2LTAyLTI0VDAyOjA2OjI5LjE3MloiLCJpZCI6Nzl9
}

settings {
  encodeUrl: true
  timeout: 0
}
