meta {
  name: list photos by event
  type: http
  seq: 1
}

get {
  url: {{base_url}}/photos/event/{{event_token}}?limit={{limit}}
  body: none
  auth: inherit
}

params:query {
  limit: {{limit}}
}

headers {
  ~Authorization: Bearer {{token}}
}

vars:pre-request {
  event_token: 1487f80e-78db-426b-81de-ef56b1e62af8
  limit: 99
  cursor: eyJjcmVhdGVkQXQiOiIyMDI2LTAyLTI0VDAyOjA2OjI5LjE3MloiLCJpZCI6Nzl9
}

settings {
  encodeUrl: true
  timeout: 0
}
