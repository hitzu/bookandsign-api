meta {
  name: get event by token
  type: http
  seq: 2
}

get {
  url: {{base_url}}/events/{{event_token}}
  body: none
  auth: inherit
}

headers {
  ~Authorization: Bearer {{token}}
}

vars:pre-request {
  event_token: db69c995-b30b-40b4-85e7-c01a79eff1a1
}

settings {
  encodeUrl: true
  timeout: 0
}
