meta {
  name: get event by token
  type: http
  seq: 2
}

get {
  url: {{base_url}}/events/{{event_token}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

vars:pre-request {
  event_token: 1487f80e-78db-426b-81de-ef56b1e62af8
}

settings {
  encodeUrl: true
  timeout: 0
}
