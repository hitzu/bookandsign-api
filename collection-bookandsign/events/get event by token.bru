meta {
  name: get event by token
  type: http
  seq: 2
}

get {
  url: {{base_url}}/events/{{event_token}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

vars:pre-request {
  event_token: 4b5afc47-18a8-4df2-a9eb-4855dea500de
}

settings {
  encodeUrl: true
  timeout: 0
}
