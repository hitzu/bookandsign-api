meta {
  name: create event
  type: http
  seq: 1
}

post {
  url: {{base_url}}/events
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "contractId": {{contract_id}},
    "name": "Stephanie & Marco",
    "description": "Hoy, mañana y siempre",
    "key": "07-03-26"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
