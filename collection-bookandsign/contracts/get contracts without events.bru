meta {
  name: get contracts without events
  type: http
  seq: 17
}

get {
  url: {{base_url}}/contracts?excludeWithEvents=true
  body: json
  auth: inherit
}

params:query {
  excludeWithEvents: true
}

headers {
  authorization: Bearer {{token}}
}

vars:pre-request {
  contract_id: 5
}

settings {
  encodeUrl: true
  timeout: 0
}
