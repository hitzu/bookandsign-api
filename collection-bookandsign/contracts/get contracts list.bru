meta {
  name: get contracts list
  type: http
  seq: 15
}

get {
  url: {{base_url}}/contracts?includeFinalized=true
  body: json
  auth: inherit
}

params:query {
  includeFinalized: true
}

headers {
  authorization: Bearer {{token}}
}

vars:pre-request {
  contract_id: 5
}

settings {
  encodeUrl: true
  timeout: 0
}
